# threat-dash environment variables
# Copy this file to .env and fill in your API keys for local development.
# NEVER commit .env to version control.

# --- Third-party API keys ---
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here
ABUSEIPDB_API_KEY=your_abuseipdb_api_key_here
GREYNOISE_API_KEY=your_greynoise_api_key_here

# --- Anthropic (Phase 4 — Executive Summary generation) ---
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- App config ---
# Set to true in deployed environments to serve cached sample data (no API keys needed)
DEMO_MODE=false

# SQLite database file path (relative to project root)
DATABASE_PATH=threat_dash.db
